# ============================================================
# APP
# ============================================================
PROJECT_NAME="Banknote Recognition API"
ENV="development"

# ============================================================
# DATABASE
# ============================================================
MONGODB_URL="mongodb://localhost:27017"
DATABASE_NAME="banknote_system"

# ============================================================
# SECURITY
# ============================================================
SECRET_KEY="your_strong_random_secret_key_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================
# FRONTEND / CORS (BACKEND)
# ============================================================
FRONTEND_URL="http://localhost:5173"
ALLOW_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# ============================================================
# GOOGLE API / GEMINI
# ============================================================
GOOGLE_API_KEY="your_google_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# ============================================================
# GOOGLE AUTH OAUTH2
# ============================================================
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# ============================================================
# IMAGE SEARCH / UPLOAD
# ============================================================
IMGBB_API_KEY="your_imgbb_api_key_here"
SERPAPI_KEY="your_serpapi_key_here"

# ============================================================
# CLOUDINARY
# ============================================================
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"

# ============================================================
# CHROME / SELENIUM
# ============================================================
CHROME_HEADLESS="True"
CHROME_BINARY_PATH="your_chrome_binary_path_here"
CHROMEDRIVER_PATH="your_chromedriver_path_here"
PAGE_LOAD_TIMEOUT=45

# ============================================================
# AGENT 1 ML/DL
# ============================================================
AGENT1_YOLO_MODEL_PATH="ml_models/yolo/best.pt"
AGENT1_RES_MODEL_PATH="ml_models/res/banknote_resnet50_stable_best.pth"
AGENT1_RES_CLASSES_PATH="ml_models/res/classes.txt"
AGENT1_YOLO_CONF=0.25
AGENT1_YOLO_IMGSZ=640
AGENT1_RES_IMGSZ=224

# ============================================================
# AGENT 3 CONFIG DEFAULTS
# ============================================================
AGENT3_PROVIDER="serpapi"
AGENT3_FALLBACK_ENABLED="True"
AGENT3_FALLBACK_PROVIDER="serpapi"
AGENT3_V2_ENABLED="True"

# ============================================================
# SEP PAY / VIETQR PAYMENT
# ============================================================
SEPAY_API_KEY="your_sepay_api_key_here"
SEPAY_API_TOKEN="your_sepay_token_here"
SEPAY_ACCOUNT_NUMBER="your_sepay_account_number_here"
SEPAY_BANK_BRAND="your_sepay_bank_brand_here"

BANK_ACCOUNT_NUMBER="your_bank_account_number_here"
BANK_ID="your_bank_id_here"
ACCOUNT_NAME="your_account_name_here"
NAME_WEB="BANKNOTEAI"

# ============================================================
# VNPAY PAYMENT
# ============================================================
VNP_TMNCODE="your_vnp_tmncode_here"
VNP_HASHSECRET="your_vnp_hashsecret_here"
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNP_RETURNURL="http://localhost:5173/vnpay-return"

# ============================================================
# EMAIL / SMTP
# ============================================================
EMAIL_NOTIFICATIONS_ENABLED="False"
SMTP_HOST="your_smtp_host_here"
SMTP_PORT=587
SMTP_USERNAME="your_smtp_username_here"
SMTP_PASSWORD="your_smtp_password_here"
SMTP_FROM_EMAIL="your_smtp_from_email_here"
SMTP_FROM_NAME="BanknoteAI"

# ============================================================
# CURRENCY PROVIDER
# ============================================================
CURRENCY_PROVIDER_NAME="your_currency_provider_name_here"
CURRENCY_PROVIDER_API_KEY="your_currency_provider_api_key_here"
CURRENCY_STALE_AFTER_HOURS=24
